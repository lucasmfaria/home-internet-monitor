    {
      "id": 5,
      "title": "Last Download Speed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"internet_monitor\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"speed_test\" and r._field == \"download_mbps\")\n  |> last()"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 25 }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 100 } ] } }, "overrides": [] },
