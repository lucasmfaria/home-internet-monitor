      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"internet_monitor\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"ping_result\" and r._field == \"success\")\n  |> group()\n  |> mean()\n  |> map(fn: (r) => ({ r with _value: r._value * 100.0 }))"
        }
