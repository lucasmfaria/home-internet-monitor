          "query": "from(bucket: \"internet_monitor\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"speed_test\" and r._field == \"download_mbps\")"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "pointSize": 5, "showPoints": "always", "spanNulls": false, "lineInterpolation": "smooth" }, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
