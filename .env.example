# ============================================================
# Home Internet Monitor — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- InfluxDB ---
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=home-monitor
INFLUXDB_BUCKET=internet_monitor
INFLUXDB_ADMIN_USERNAME=admin
INFLUXDB_ADMIN_PASSWORD=changeme_strong_password_here
INFLUXDB_ADMIN_TOKEN=my-super-secret-token-change-me

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# --- Ping Monitor ---
PING_TARGETS=8.8.8.8,1.1.1.1,208.67.222.222
PING_INTERVAL=5
PING_TIMEOUT=2
CONSECUTIVE_FAILURES_THRESHOLD=3

# --- Speed Tester ---
SPEED_TEST_INTERVAL=30

# --- Telegram Alerting ---
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=
# Send a message to @userinfobot to get your chat ID
TELEGRAM_CHAT_ID=

# --- Data Retention (days) ---
DATA_RETENTION_DAYS=180
