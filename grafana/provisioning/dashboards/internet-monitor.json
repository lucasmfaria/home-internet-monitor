    {
      "id": 7,
      "title": "Ping Latency (RTT)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"internet_monitor\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"ping_result\" and r._field == \"rtt_ms\" and r._value > 0)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "pointSize": 3, "showPoints": "auto", "spanNulls": false } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "min"] } }
    },
    {
      "id": 8,
      "title": "Connection State Timeline",
      "type": "state-timeline",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"internet_monitor\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"ping_result\" and r._field == \"success\")\n  |> group(columns: [\"target\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _value: if r._value >= 0.5 then 1.0 else 0.0 }))"
        }
      ],
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "UP", "color": "green", "index": 1 } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "showValue": "auto", "mergeValues": true, "alignValue": "center" }
    },
    {
      "id": 9,
      "title": "Outage Events",
      "type": "table",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"internet_monitor\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"outage_event\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group()\n  |> sort(columns: [\"_time\"], desc: true)\n  |> keep(columns: [\"_time\", \"type\", \"duration_seconds\"])"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "duration_seconds" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "displayName", "value": "Duration" } ] }, { "matcher": { "id": "byName", "options": "type" }, "properties": [ { "id": "displayName", "value": "Event" } ] }, { "matcher": { "id": "byName", "options": "_time" }, "properties": [ { "id": "displayName", "value": "Time" } ] } ] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Time", "desc": true } ] }
    },
